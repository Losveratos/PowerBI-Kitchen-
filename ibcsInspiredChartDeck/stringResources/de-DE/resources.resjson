  "Table_TotalRowPos": "Position der Σ-Zeile",
  "Desc_Table_TotalRowPos": "Wo die Σ-Gesamtzeile steht: „Unten“ (Standard, deutsche GuV-Lesart) unter allen Zeilen, „Oben“ direkt unter dem Kopf (IBCS). Bleibt beim Scrollen fixiert.",
  "Table_ZebraStripes": "Zebra-Streifen",
  "Desc_Table_ZebraStripes": "Legt jede zweite Datenzeile mit einem sehr dezenten Hintergrund an — leichtere Zeilenverfolgung in breiten Tabellen. Im Hochkontrast-Modus aus. Standard aus.",
  "Table_RowDensity": "Zeilenhöhe",
  "Desc_Table_RowDensity": "Zeilenhöhe: „Kompakt“ für dichte Tabellen, „Normal“ (Standard) wie bisher, „Luftig“ für mehr Weißraum. Skaliert nur die Obergrenze; sehr hohe Visuals bleiben gedeckelt.",
  "Table_GridLines": "Gitterlinien",
  "Desc_Table_GridLines": "Trennlinien-Stil: „Horizontal“ (Standard) nur Zeilenlinien, „Keine“ für ein ruhiges Bild, „Horizontal + vertikal“ ergänzt dezente Spalten-/Blocktrenner.",
  "Enum_TotalPos_Bottom": "Unten (unter den Zeilen)",
  "Enum_TotalPos_Top": "Oben (unter dem Kopf)",
  "Enum_RowDensity_Compact": "Kompakt",
  "Enum_RowDensity_Normal": "Normal",
