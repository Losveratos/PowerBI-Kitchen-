# --- Daten WG Buckets · gitignore ---

# Lokales Backup (wird beim Build erzeugt, nicht versionieren)
daten_wg_learn_buckets.backup.html

# yt-dlp Caches (regenerierbar via scripts/fetch_videos.py)
videos_flat.json
videos_raw.json
.episodes_range.json

# Build-Zwischenstaende
existing_episodes.json

# yt-dlp data dir
data/

# Andere Themen / nicht zu diesem Repo
wordpress.md
drafts/
analysis/
notes/

# Lab-Seiten — erst lokal testen, ggf. spaeter publizieren
analysis.html
fermi_paradox.html

# Private Prompts / Test-Hilfen — nur lokal, nie publizieren
prompts/

# Diagnose-Helfer (entstanden waehrend Bug-Hunting, nicht produktiv)
scripts/debug_*
scripts/find_*

# Python / Node Caches
__pycache__/
*.pyc
node_modules/
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Claude Code lokal (Skills aber versionieren, damit sie „in Git" liegen)
.claude/*
!.claude/skills/
deneb-test/

# Temp: pbix-Extraktion
_gtmp/

# ChartKitchen beta gate — raw .pbiviz builds never get committed to the site
# downloads folder; the encrypted .enc IS committed there on activation.
# (Release builds under ibcsInspiredChartDeck/dist/ stay tracked as before.)
downloads/*.pbiviz
